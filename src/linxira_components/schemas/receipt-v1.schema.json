{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linxira.org/schemas/components/receipt-v1.schema.json",
  "title": "Linxira component transaction receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "requestPlanId", "planDigest", "status", "createdAt", "updatedAt", "message", "digest"],
  "properties": {
    "schemaVersion": {"const": "org.linxira.components.receipt.v1"},
    "id": {"type": "string", "format": "uuid"},
    "requestPlanId": {"type": "string", "format": "uuid"},
    "planDigest": {"$ref": "#/$defs/sha256"},
    "status": {"enum": ["planned", "confirmed", "applying", "succeeded", "failed", "stale", "interrupted"]},
    "createdAt": {"$ref": "#/$defs/utcTimestamp"},
    "updatedAt": {"oneOf": [{"$ref": "#/$defs/utcTimestamp"}, {"type": "null"}]},
    "message": {"type": ["string", "null"]},
    "digest": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "utcTimestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"}
  }
}
