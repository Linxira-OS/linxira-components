{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linxira.org/schemas/components/confirmation-v1.schema.json",
  "title": "Linxira component confirmation v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "confirmedAt", "requestPlanId", "planDigest", "catalogSha256", "architecture", "profileIds", "applicationIds", "directPackageTargets", "networkRequired", "systemUpgradeRequired", "digest"],
  "properties": {
    "schemaVersion": {"const": "org.linxira.components.confirmation.v1"},
    "id": {"type": "string", "format": "uuid"},
    "confirmedAt": {"$ref": "#/$defs/utcTimestamp"},
    "requestPlanId": {"type": "string", "format": "uuid"},
    "planDigest": {"$ref": "#/$defs/sha256"},
    "catalogSha256": {"$ref": "#/$defs/sha256"},
    "architecture": {"type": "string", "pattern": "^[A-Za-z0-9_+-]+$"},
    "profileIds": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9-]+$"}},
    "applicationIds": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9-]+$"}},
    "directPackageTargets": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9@._+-]+$"}},
    "networkRequired": {"type": "boolean"},
    "systemUpgradeRequired": {"const": false},
    "digest": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "utcTimestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"}
  }
}
