{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linxira.org/schemas/components/confirmation-v1.schema.json",
  "title": "Linxira component confirmation v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "confirmedAt", "requestPlanId", "planDigest", "catalogSha256", "digest"],
  "properties": {
    "schemaVersion": {"const": "org.linxira.components.confirmation.v1"},
    "id": {"type": "string", "format": "uuid"},
    "confirmedAt": {"$ref": "#/$defs/utcTimestamp"},
    "requestPlanId": {"type": "string", "format": "uuid"},
    "planDigest": {"$ref": "#/$defs/sha256"},
    "catalogSha256": {"$ref": "#/$defs/sha256"},
    "digest": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "utcTimestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"}
  }
}
