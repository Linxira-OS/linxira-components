{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linxira.org/schemas/components/confirmation-v2.schema.json",
  "title": "Linxira Catalog v3 confirmation v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "confirmedAt", "requestPlanId", "planDigest", "catalogSha256", "catalogRelease", "architecture", "selection", "finalLeafIds", "selectedBundleIds", "leafRequirements", "providerRequirements", "sourceRequirements", "pendingItems", "unsupportedItems", "directPackageTargets", "networkRequired", "systemUpgradeRequired", "digest"],
  "properties": {
    "schemaVersion": {"const": "org.linxira.components.confirmation.v2"},
    "id": {"type": "string", "format": "uuid"},
    "confirmedAt": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "requestPlanId": {"type": "string", "format": "uuid"},
    "planDigest": {"$ref": "#/$defs/sha256"},
    "catalogSha256": {"$ref": "#/$defs/sha256"},
    "catalogRelease": {"type": "string", "minLength": 1},
    "architecture": {"type": "string", "minLength": 1},
    "selection": {"type": "object"},
    "finalLeafIds": {"$ref": "#/$defs/ids"},
    "selectedBundleIds": {"$ref": "#/$defs/ids"},
    "leafRequirements": {"type": "array", "items": {"type": "object"}},
    "providerRequirements": {"$ref": "#/$defs/ids"},
    "sourceRequirements": {"$ref": "#/$defs/ids"},
    "pendingItems": {"$ref": "#/$defs/ids"},
    "unsupportedItems": {"$ref": "#/$defs/ids"},
    "directPackageTargets": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9@._+-]+$"}},
    "networkRequired": {"type": "boolean"},
    "systemUpgradeRequired": {"const": false},
    "digest": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
